{
  "include": [
    "app/**/*",
    "eslint.config.js",
    "next-env.d.ts",
    "src/**/*",
    ".next/types/**/*.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "preserve",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["next"],
    "baseUrl": ".",
    /* Bundler mode */
    "verbatimModuleSyntax": false,
    "noEmit": true,
    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "allowJs": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["node_modules", "src/server.ts", "src/start.ts"]
}
